<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F0F4F8"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="System Connection"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <EditText
                android:id="@+id/editMasterIp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="Master IP (e.g. 10.0.2.2)"
                android:text="10.0.2.2"
                android:inputType="text" />

            <EditText
                android:id="@+id/editMasterPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Port"
                android:text="5000"
                android:inputType="number" />
        </LinearLayout>

        <EditText
            android:id="@+id/editPlayerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Player ID (e.g. user01)" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect to Master"
            android:backgroundTint="#4CAF50" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Disconnected"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Search Filters ---"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editRisk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Risk (low, medium, high, *)" />

        <EditText
            android:id="@+id/editBetCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bet Limit ($, $$, $$$, *)" />

        <EditText
            android:id="@+id/editStars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Min Stars (1-5, *)" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search Games" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search Results (Tap to select):"
            android:textStyle="italic"
            android:layout_marginTop="8dp"/>

        <ListView
            android:id="@+id/listGames"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#FFFFFF"
            android:divider="#CCCCCC"
            android:dividerHeight="1dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Play Game ---"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editGameName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Game Name" />

        <EditText
            android:id="@+id/editBetAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Bet Amount" />

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Add Balance ---"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editBalanceAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Amount to Add" />

        <Button
            android:id="@+id/btnAddBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Tokens" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>