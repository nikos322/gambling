<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/editPlayerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Player ID (e.g. user123)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Search Filters ---"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editRisk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Risk (low, medium, high, *)" />

        <EditText
            android:id="@+id/editBetCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bet Limit ($, $$, $$$, *)" />

        <EditText
            android:id="@+id/editStars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="Min Stars (1-5, *)" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search Games" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Play Game ---"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editGameName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Game Name" />

        <EditText
            android:id="@+id/editBetAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Bet Amount" />

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Add Balance ---"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/editBalanceAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Amount to Add" />

        <Button
            android:id="@+id/btnAddBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Tokens" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Console Output:"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/textConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:textSize="12sp"
            android:minLines="10"/>

    </LinearLayout>
</ScrollView>